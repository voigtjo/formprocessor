<%- include('../partials/header', { title }) %>
<div class="space-y-4">
  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h1 class="mb-4 text-xl font-semibold">Customer Orders</h1>
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-700">Start Customer Order</h2>
    <form method="post" action="/ui-actions/customer-orders/start" class="grid grid-cols-1 gap-3 md:grid-cols-4">
      <div>
        <label class="block text-sm font-medium text-slate-700">Template</label>
        <select name="templateId" required class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm">
          <option value="">Select template...</option>
          <% for (const t of startTemplates) { %>
            <option value="<%= t.templateId %>"><%= t.name %> (<%= t.key %>)</option>
          <% } %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Customer</label>
        <select id="customer-select" name="customer_id" required class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm">
          <option value="" disabled <%= !selectedCustomerId ? 'selected' : '' %>>Select customer...</option>
          <% for (const c of validCustomers) { %>
            <option value="<%= c.id %>" <%= selectedCustomerId === c.id ? 'selected' : '' %>><%= c.name %></option>
          <% } %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Order No</label>
        <select id="customer-order-select" name="customerOrderId" required <%= !selectedCustomerId ? 'disabled' : '' %> class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm">
          <% if (!selectedCustomerId) { %>
            <option value="" selected disabled>Select customer first...</option>
          <% } else { %>
            <option value="" selected disabled>Select order no...</option>
            <% for (const o of validCustomerOrders) { %>
              <option value="<%= o.id %>"><%= o.order_no %></option>
            <% } %>
          <% } %>
        </select>
      </div>
      <div class="flex items-end gap-2">
        <button
          type="submit"
          formmethod="get"
          formaction="/ui/customer-orders"
          formnovalidate
          class="rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
        >
          Load Orders
        </button>
        <button type="submit" class="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700">Start Customer Order</button>
      </div>
    </form>
  </div>

  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Existing Customer Orders</h2>
    <% if (!items.length) { %>
      <p class="text-sm text-slate-500">No customer order entities yet.</p>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-slate-600">
            <tr>
              <th class="px-3 py-2 text-left font-medium">Template</th>
              <th class="px-3 py-2 text-left font-medium">Version</th>
              <th class="px-3 py-2 text-left font-medium">Status</th>
              <th class="px-3 py-2 text-left font-medium">Key</th>
              <th class="px-3 py-2 text-left font-medium">Created</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white">
            <% for (const item of items) { %>
              <tr>
                <td class="px-3 py-2"><a class="text-sky-700 hover:text-sky-900" href="/ui/entities/<%= item.id %>"><%= item.templateName %> (<code><%= item.templateKey %></code>)</a></td>
                <td class="px-3 py-2"><%= item.versionChannel %> <span class="text-slate-600"><%= `${item.versionMajor}.${item.versionMinor}.${item.versionPatch}` %></span></td>
                <td class="px-3 py-2"><%= item.status %></td>
                <td class="px-3 py-2"><%= item.businessKey ?? '-' %></td>
                <td class="px-3 py-2"><%= new Date(item.createdAt).toISOString() %></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
