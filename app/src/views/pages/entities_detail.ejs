<%- include('../partials/header', { title }) %>
<div class="space-y-4">
  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h1 class="mb-4 text-xl font-semibold">Entity Detail</h1>
    <dl class="grid grid-cols-1 gap-3 text-sm md:grid-cols-2">
      <div><dt class="font-medium text-slate-600">ID</dt><dd><code><%= entity.id %></code></dd></div>
      <div><dt class="font-medium text-slate-600">Template</dt><dd><%= template.name %> (<code><%= template.key %></code>)</dd></div>
      <div><dt class="font-medium text-slate-600">Template Type</dt><dd><%= template.type %></dd></div>
      <div><dt class="font-medium text-slate-600">Version</dt><dd><%= version.channel %> <%= `${version.major}.${version.minor}.${version.patch}` %></dd></div>
      <div><dt class="font-medium text-slate-600"><%= headerInfo?.assignmentTitle ?? 'Assignment' %></dt><dd><%= headerInfo?.assignmentLabel ?? '-' %></dd></div>
      <div><dt class="font-medium text-slate-600"><%= headerInfo?.keyTitle ?? 'Key' %></dt><dd><%= headerInfo?.keyLabel ?? '-' %></dd></div>
      <div><dt class="font-medium text-slate-600">Status</dt><dd><%= entity.status %></dd></div>
      <div><dt class="font-medium text-slate-600">Business Key</dt><dd><%= entity.businessKey ?? '-' %></dd></div>
      <div><dt class="font-medium text-slate-600">Created</dt><dd><%= new Date(entity.createdAt).toISOString() %></dd></div>
    </dl>
  </div>

  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Header</h2>
    <dl class="grid grid-cols-1 gap-3 text-sm md:grid-cols-2">
      <div><dt class="font-medium text-slate-600"><%= headerInfo?.assignmentTitle ?? 'Assignment' %></dt><dd><%= headerInfo?.assignmentLabel ?? '-' %></dd></div>
      <div><dt class="font-medium text-slate-600"><%= headerInfo?.keyTitle ?? 'Key' %></dt><dd><%= headerInfo?.keyLabel ?? '-' %></dd></div>
    </dl>
  </div>

  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <div class="mb-4 flex flex-wrap items-center gap-2">
      <% if (entity.status === 'DRAFT') { %>
        <button type="submit" form="entity-save-form" class="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700">Save</button>
        <form method="post" action="/ui-actions/entities/<%= entity.id %>/submit">
          <button type="submit" class="rounded-md bg-amber-700 px-3 py-2 text-sm font-medium text-white hover:bg-amber-600">Submit</button>
        </form>
        <form method="post" action="/ui-actions/entities/<%= entity.id %>/delete" onsubmit="return window.confirm('Delete this entity draft?');">
          <button type="submit" class="rounded-md bg-rose-700 px-3 py-2 text-sm font-medium text-white hover:bg-rose-600">Delete</button>
        </form>
      <% } %>
      <% if (entity.status === 'SUBMITTED') { %>
        <form method="post" action="/ui-actions/entities/<%= entity.id %>/approve">
          <button type="submit" class="rounded-md bg-emerald-700 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-600">Approve</button>
        </form>
        <form method="post" action="/ui-actions/entities/<%= entity.id %>/reject">
          <button type="submit" class="rounded-md bg-rose-700 px-3 py-2 text-sm font-medium text-white hover:bg-rose-600">Reject</button>
        </form>
      <% } %>
    </div>

    <form id="entity-save-form" method="post" action="/ui-actions/entities/<%= entity.id %>/save" class="space-y-4">
      <%- formHtml %>
    </form>
  </div>

  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Approvals</h2>
    <% if (!approvals.length) { %>
      <p class="text-sm text-slate-500">No approval actions yet.</p>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-slate-600">
            <tr>
              <th class="px-3 py-2 text-left font-medium">Decision</th>
              <th class="px-3 py-2 text-left font-medium">Actor</th>
              <th class="px-3 py-2 text-left font-medium">Comment</th>
              <th class="px-3 py-2 text-left font-medium">Created</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white">
            <% for (const a of approvals) { %>
              <tr>
                <td class="px-3 py-2"><%= a.decision %></td>
                <td class="px-3 py-2"><code><%= a.actorUserId ?? '-' %></code></td>
                <td class="px-3 py-2"><%= a.comment ?? '-' %></td>
                <td class="px-3 py-2"><%= new Date(a.createdAt).toISOString() %></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
