<%- include('../partials/header', { title }) %>
<div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
  <h1 class="mb-4 text-xl font-semibold">Entities</h1>

  <div class="mb-6 rounded-lg border border-slate-200 bg-slate-50 p-4">
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-700">Start Entity</h2>
    <form method="post" action="/ui-actions/entities/start" class="grid grid-cols-1 gap-3 md:grid-cols-3">
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-slate-700">Template (active TEST)</label>
        <select name="templateId" required class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm">
          <option value="">Select template...</option>
          <% for (const t of startTemplates) { %>
            <option value="<%= t.templateId %>"><%= t.name %> (<%= t.key %>)</option>
          <% } %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Business Key (optional)</label>
        <input name="businessKey" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" />
      </div>
      <div class="md:col-span-3">
        <button type="submit" class="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700">Start Entity</button>
      </div>
    </form>
    <% if (!startTemplates.length) { %>
      <p class="mt-2 text-sm text-amber-700">No templates with active TEST version available.</p>
    <% } %>
  </div>

  <% if (!items.length) { %>
    <p class="text-sm text-slate-500">No entities found for the default group.</p>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-3 py-2 text-left font-medium">ID</th>
            <th class="px-3 py-2 text-left font-medium">Template</th>
            <th class="px-3 py-2 text-left font-medium">Version</th>
            <th class="px-3 py-2 text-left font-medium">Status</th>
            <th class="px-3 py-2 text-left font-medium">Business Key</th>
            <th class="px-3 py-2 text-left font-medium">Created</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          <% for (const item of items) { %>
            <tr>
              <td class="px-3 py-2"><a class="text-sky-700 hover:text-sky-900" href="/ui/entities/<%= item.id %>"><code><%= item.id %></code></a></td>
              <td class="px-3 py-2"><%= item.templateName %> (<code><%= item.templateKey %></code>)</td>
              <td class="px-3 py-2"><%= item.versionChannel %> <span class="text-slate-600"><%= `${item.versionMajor}.${item.versionMinor}.${item.versionPatch}` %></span></td>
              <td class="px-3 py-2"><%= item.status %></td>
              <td class="px-3 py-2"><%= item.businessKey ?? '-' %></td>
              <td class="px-3 py-2"><%= new Date(item.createdAt).toISOString() %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
