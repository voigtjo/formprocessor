<%- include('../partials/header', { title }) %>
<div class="space-y-4">
  <% const isProductionType = String(template.templateType || '').includes('PRODUCTION_ORDER'); %>
  <% const resolvedAssignment = template.assignmentField ?? (template.templateType === 'CUSTOMER_ORDER' ? 'customer_id' : 'product_id'); %>
  <% const resolvedKey = template.keyField ?? (template.templateType === 'CUSTOMER_ORDER' ? 'customer_order_id' : ((template.templateType === 'PRODUCTION_ORDER_SERIAL' || template.templateType === 'SERIAL_PRODUCTION_ORDER') ? 'serial_no' : 'batch_id')); %>
  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h1 class="mb-4 text-xl font-semibold">Template Detail</h1>
    <dl class="grid grid-cols-1 gap-3 text-sm md:grid-cols-2">
      <div><dt class="font-medium text-slate-600">ID</dt><dd><code><%= template.id %></code></dd></div>
      <div><dt class="font-medium text-slate-600">Key</dt><dd><code><%= template.key %></code></dd></div>
      <div><dt class="font-medium text-slate-600">Name</dt><dd><%= template.name %></dd></div>
      <div><dt class="font-medium text-slate-600">Template Type</dt><dd><%= template.templateType %></dd></div>
      <div><dt class="font-medium text-slate-600">Header Config</dt><dd>assignment=<code><%= resolvedAssignment %></code>, key=<code><%= resolvedKey %></code></dd></div>
      <div><dt class="font-medium text-slate-600">Created</dt><dd><%= new Date(template.createdAt).toISOString() %></dd></div>
      <div class="md:col-span-2"><dt class="font-medium text-slate-600">Description</dt><dd><%= template.description ?? '-' %></dd></div>
    </dl>
  </div>

  <% if (isProductionType) { %>
    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="mb-3 text-lg font-semibold">Edit Header Config</h2>
      <form method="post" action="/ui-actions/forms/<%= template.id %>/header-config" class="grid grid-cols-1 gap-3 md:grid-cols-3">
        <div>
          <label class="block text-sm font-medium text-slate-700">assignment_field</label>
          <select name="assignment_field" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
            <% for (const option of headerFieldOptions) { %>
              <option value="<%= option.key %>" <%= resolvedAssignment === option.key ? 'selected' : '' %>><%= option.key %> (<%= option.label %>)</option>
            <% } %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700">key_field</label>
          <select name="key_field" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
            <% for (const option of headerFieldOptions) { %>
              <option value="<%= option.key %>" <%= resolvedKey === option.key ? 'selected' : '' %>><%= option.key %> (<%= option.label %>)</option>
            <% } %>
          </select>
        </div>
        <div class="flex items-end">
          <button type="submit" class="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700">Save Header Config</button>
        </div>
      </form>
    </div>
  <% } %>

  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Versions</h2>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-3 py-2 text-left font-medium">Channel</th>
            <th class="px-3 py-2 text-left font-medium">Version</th>
            <th class="px-3 py-2 text-left font-medium">Active</th>
            <th class="px-3 py-2 text-left font-medium">Created At</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          <% for (const v of versions) { %>
            <tr>
              <td class="px-3 py-2"><%= v.channel %></td>
              <td class="px-3 py-2"><%= `${v.major}.${v.minor}.${v.patch}` %></td>
              <td class="px-3 py-2"><%= v.isActive ? 'yes' : 'no' %></td>
              <td class="px-3 py-2"><%= new Date(v.createdAt).toISOString() %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Latest TEST JSON</h2>
    <form method="post" action="/ui-actions/forms/<%= template.id %>/save-test" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700">field_defs_json</label>
        <textarea name="field_defs_json" rows="10" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 font-mono text-xs"><%= initialFieldDefsJson %></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">layout_json</label>
        <textarea name="layout_json" rows="10" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 font-mono text-xs"><%= initialLayoutJson %></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">rules_json</label>
        <textarea name="rules_json" rows="10" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 font-mono text-xs"><%= initialRulesJson %></textarea>
      </div>
      <div class="flex flex-wrap gap-2">
        <button type="submit" class="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700">Save TEST JSON</button>
      </div>
    </form>

    <div class="mt-4 flex flex-wrap gap-2">
      <form method="post" action="/ui-actions/forms/<%= template.id %>/reset-starter">
        <button type="submit" class="rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Reset to Starter</button>
      </form>
      <form method="post" action="/ui-actions/forms/<%= template.id %>/publish-test">
        <button type="submit" class="rounded-md bg-emerald-700 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-600">Publish TEST</button>
      </form>
      <form method="post" action="/ui-actions/forms/<%= template.id %>/publish-prod">
        <button type="submit" class="rounded-md bg-indigo-700 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-600">Publish PROD</button>
      </form>
    </div>
  </div>

  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Preview</h2>
    <% if (previewError) { %>
      <p class="rounded-md bg-rose-50 px-3 py-2 text-sm text-rose-700"><%= previewError %></p>
    <% } else { %>
      <%- previewHtml %>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
