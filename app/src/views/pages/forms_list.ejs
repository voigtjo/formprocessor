<%- include('../partials/header', { title }) %>
<div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
  <div class="mb-4 flex items-center justify-between">
    <h1 class="text-xl font-semibold">Templates</h1>
    <a href="/ui/forms/new" class="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700">Create template</a>
  </div>

  <% if (!items.length) { %>
    <p class="text-sm text-slate-500">No templates yet.</p>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-3 py-2 text-left font-medium">Name</th>
            <th class="px-3 py-2 text-left font-medium">Key</th>
            <th class="px-3 py-2 text-left font-medium">Created</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          <% for (const item of items) { %>
            <tr>
              <td class="px-3 py-2"><a class="text-sky-700 hover:text-sky-900" href="/ui/forms/<%= item.id %>"><%= item.name %></a></td>
              <td class="px-3 py-2"><code><%= item.key %></code></td>
              <td class="px-3 py-2 text-slate-600"><%= new Date(item.createdAt).toISOString() %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
