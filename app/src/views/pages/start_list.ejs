<%- include('../partials/header', { title }) %>
<div class="space-y-4">
  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h1 class="mb-4 text-xl font-semibold">Start</h1>
    <form id="start-form" method="post" action="/ui-actions/start" class="grid grid-cols-1 gap-3 md:grid-cols-5">
      <div>
        <label class="block text-sm font-medium text-slate-700">Form Type</label>
        <select
          id="start-type-select"
          name="type"
          class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm"
          onchange="window.location.href='/ui/start?type=' + encodeURIComponent(this.value)"
        >
          <% for (const t of formTypes) { %>
            <option value="<%= t.id %>" <%= selectedType === t.id ? 'selected' : '' %>><%= t.label %></option>
          <% } %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Template</label>
        <select
          id="start-template-select"
          name="templateId"
          required
          class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm"
          onchange="(function(sel){const q=new URLSearchParams({type:document.getElementById('start-type-select').value});if(sel.value)q.set('templateId',sel.value);window.location.href='/ui/start?'+q.toString();})(this)"
        >
          <option value="">Select template...</option>
          <% for (const t of startTemplates) { %>
            <option value="<%= t.templateId %>" <%= selectedTemplateId === t.templateId ? 'selected' : '' %>><%= t.name %> (<%= t.key %>)</option>
          <% } %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700"><%= effectiveConfig.assignment.label %></label>
        <select
          id="start-assignment-select"
          name="assignmentId"
          required
          class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm"
          onchange="(function(sel){const type=document.getElementById('start-type-select').value;const templateId=document.getElementById('start-template-select').value;const q=new URLSearchParams({type:type});if(templateId)q.set('templateId',templateId);if(sel.value)q.set('assignmentId',sel.value);window.location.href='/ui/start?'+q.toString();})(this)"
        >
          <option value="" disabled <%= !selectedAssignmentId ? 'selected' : '' %>>Select <%= effectiveConfig.assignment.label.toLowerCase() %>...</option>
          <% for (const row of assignmentOptions) { %>
            <option value="<%= row.id %>" <%= selectedAssignmentId === row.id ? 'selected' : '' %>><%= row.label %></option>
          <% } %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700"><%= effectiveConfig.key.label %></label>
        <select
          id="start-key-select"
          name="keyId"
          required
          class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm"
          onchange="(function(sel){const type=document.getElementById('start-type-select').value;const templateId=document.getElementById('start-template-select').value;const assignmentId=document.getElementById('start-assignment-select').value;const q=new URLSearchParams({type:type});if(templateId)q.set('templateId',templateId);if(assignmentId)q.set('assignmentId',assignmentId);if(sel.value)q.set('keyId',sel.value);window.location.href='/ui/start?'+q.toString();})(this)"
        >
          <option value="" disabled <%= !selectedKeyId ? 'selected' : '' %>>Select <%= effectiveConfig.key.label.toLowerCase() %>...</option>
          <% for (const row of keyOptions) { %>
            <option value="<%= row.id %>" <%= selectedKeyId === row.id ? 'selected' : '' %>><%= row.label %></option>
          <% } %>
        </select>
      </div>
      <div class="flex items-end gap-2">
        <button type="submit" class="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700">Start</button>
      </div>
    </form>
  </div>

  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Existing</h2>
    <% if (!items.length) { %>
      <p class="text-sm text-slate-500">No entities for this form type yet.</p>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-slate-600">
            <tr>
              <th class="px-3 py-2 text-left font-medium">Template</th>
              <th class="px-3 py-2 text-left font-medium">Version</th>
              <th class="px-3 py-2 text-left font-medium">Status</th>
              <th class="px-3 py-2 text-left font-medium">Assignment</th>
              <th class="px-3 py-2 text-left font-medium">Key</th>
              <th class="px-3 py-2 text-left font-medium">Created</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white">
            <% for (const item of items) { %>
              <tr>
                <td class="px-3 py-2"><a class="text-sky-700 hover:text-sky-900" href="/ui/entities/<%= item.id %>"><%= item.templateName %> (<code><%= item.templateKey %></code>)</a></td>
                <td class="px-3 py-2"><%= item.versionChannel %> <span class="text-slate-600"><%= `${item.versionMajor}.${item.versionMinor}.${item.versionPatch}` %></span></td>
                <td class="px-3 py-2"><%= item.status %></td>
                <td class="px-3 py-2"><%= item.dataJson?._header?.assignment?.label ?? '-' %></td>
                <td class="px-3 py-2"><%= item.dataJson?.batch_code ?? item.dataJson?.serial_no ?? item.dataJson?.order_no ?? item.dataJson?._header?.key?.label ?? '-' %></td>
                <td class="px-3 py-2"><%= new Date(item.createdAt).toISOString() %></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
