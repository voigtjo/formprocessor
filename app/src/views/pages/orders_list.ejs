<%- include('../partials/header', { title }) %>
<div class="space-y-4">
  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h1 class="mb-4 text-xl font-semibold">Production Orders</h1>
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-700">Start Auftrag</h2>
    <form method="post" action="/ui-actions/orders/start" class="grid grid-cols-1 gap-3 md:grid-cols-4">
      <div>
        <label class="block text-sm font-medium text-slate-700">PRODUCTION_ORDER Template</label>
        <select name="templateId" required class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm">
          <option value="">Select template...</option>
          <% for (const t of startTemplates) { %>
            <option value="<%= t.templateId %>"><%= t.name %> (<%= t.key %>)</option>
          <% } %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Product</label>
        <select id="order-product-select" name="productId" required class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm">
          <% for (const p of validProducts) { %>
            <option value="<%= p.id %>" <%= initialProductId === p.id ? 'selected' : '' %>><%= p.name %></option>
          <% } %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Batch</label>
        <select id="order-batch-select" name="batchId" required class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm">
          <% for (const b of validBatches) { %>
            <option value="<%= b.id %>"><%= b.code %></option>
          <% } %>
        </select>
      </div>
      <div class="flex items-end">
        <button type="submit" class="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700">Start Auftrag</button>
      </div>
    </form>
  </div>

  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Existing Production Orders</h2>
    <% if (!items.length) { %>
      <p class="text-sm text-slate-500">No order entities yet.</p>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-slate-600">
            <tr>
              <th class="px-3 py-2 text-left font-medium">Template</th>
              <th class="px-3 py-2 text-left font-medium">Version</th>
              <th class="px-3 py-2 text-left font-medium">Status</th>
              <th class="px-3 py-2 text-left font-medium">Key</th>
              <th class="px-3 py-2 text-left font-medium">Created</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white">
            <% for (const item of items) { %>
              <tr>
                <td class="px-3 py-2"><a class="text-sky-700 hover:text-sky-900" href="/ui/entities/<%= item.id %>"><%= item.templateName %> (<code><%= item.templateKey %></code>)</a></td>
                <td class="px-3 py-2"><%= item.versionChannel %> <span class="text-slate-600"><%= `${item.versionMajor}.${item.versionMinor}.${item.versionPatch}` %></span></td>
                <td class="px-3 py-2"><%= item.status %></td>
                <td class="px-3 py-2"><%= item.businessKey ?? '-' %></td>
                <td class="px-3 py-2"><%= new Date(item.createdAt).toISOString() %></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
<script>
  (() => {
    const productSelect = document.getElementById("order-product-select");
    const batchSelect = document.getElementById("order-batch-select");
    if (!productSelect || !batchSelect) return;

    async function reloadBatches() {
      const productId = productSelect.value;
      if (!productId) return;
      const res = await fetch(`/api/batches?product_id=${encodeURIComponent(productId)}&valid=true`);
      if (!res.ok) return;
      const items = await res.json();
      batchSelect.innerHTML = "";
      for (const item of items) {
        const option = document.createElement("option");
        option.value = item.id;
        option.textContent = item.code;
        batchSelect.appendChild(option);
      }
    }

    productSelect.addEventListener("change", reloadBatches);
  })();
</script>
<%- include('../partials/footer') %>
